# Port du serveur backend
PORT=5000
NODE_ENV=development

# Base de données MongoDB (Atlas ou locale)
MONGO_URI=mongodb://127.0.0.1:27017/lms_platform

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# URL du frontend (pour les liens de redirection Stripe et CORS)
CLIENT_URL=http://localhost:5500

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx

# Email (Nodemailer - ex: SMTP Gmail, Mailtrap, Brevo...)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM="LMS Platform <no-reply@lmsplatform.com>"

# Compte admin créé automatiquement par le script de seed
ADMIN_EMAIL=admin@lmsplatform.com
ADMIN_PASSWORD=Admin123!
